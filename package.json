{
  "name": "postflow",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:cron": "ts-node --esm cron-worker.ts",
    "build": "next build && npx tsc cron-worker.ts --outDir dist --esModuleInterop --module commonjs --skipLibCheck",
    "start": "next start",
    "start:cron": "node dist/cron-worker.js",
    "deploy": "pm2 start ecosystem.config.js",
    "lint": "next lint",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@types/node-cron": "^3.0.11",
    "axios": "^1.7.9",
    "class-variance-authority": "^0.7.1",
    "cloudinary": "^2.5.1",
    "clsx": "^2.1.1",
    "dotenv": "^16.6.1",
    "lucide-react": "^0.469.0",
    "next": "14.2.20",
    "node-cron": "^4.5.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "swr": "^2.3.0",
    "tailwind-merge": "^2.6.0",
    "tailwindcss-animate": "^1.0.7",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.5.2",
    "eslint": "^8",
    "eslint-config-next": "14.2.20",
    "postcss": "^8",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  }
}
